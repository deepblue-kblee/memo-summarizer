#!/usr/bin/env python3
"""
Agent Team 시뮬레이션 도구

워크플로우 시뮬레이션을 실행하는 전용 스크립트
"""

import sys
import os
import click

# 스크립트 경로를 Python 경로에 추가
script_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, script_dir)


@click.command()
@click.option("--scenario", "-s", help="실행할 특정 시나리오 이름")
@click.option("--list", "list_scenarios", is_flag=True, help="사용 가능한 시나리오 목록 조회")
@click.option("--info", help="특정 시나리오 정보 조회")
@click.option("--db-path", help="SQLite 데이터베이스 파일 경로")
def simulate(scenario, list_scenarios, info, db_path):
    """Agent Team 워크플로우 시뮬레이션"""
    try:
        from agent_team.harness.simulator import WorkflowSimulator
        from agent_team.harness.agent_team import AgentTeam
        from rich.console import Console
        from rich.table import Table

        console = Console()

        # 에이전트 팀 생성
        agent_team = AgentTeam(db_path=db_path)
        simulator = WorkflowSimulator(agent_team)

        if list_scenarios:
            # 시나리오 목록 출력
            scenarios = simulator.list_scenarios()

            table = Table(title="사용 가능한 시뮬레이션 시나리오")
            table.add_column("이름", style="cyan")
            table.add_column("설명", style="white")

            for scenario_name in scenarios:
                scenario_info = simulator.get_scenario_info(scenario_name)
                if scenario_info:
                    table.add_row(scenario_name, scenario_info["description"])

            console.print(table)
            return

        if info:
            # 시나리오 정보 출력
            scenario_info = simulator.get_scenario_info(info)
            if scenario_info:
                console.print(f"[bold blue]시나리오:[/bold blue] {scenario_info['name']}")
                console.print(f"[bold green]설명:[/bold green] {scenario_info['description']}")
                console.print(f"[bold yellow]요청:[/bold yellow] {scenario_info['user_request']}")
                console.print(f"[bold cyan]예상 결과:[/bold cyan] {scenario_info['expected_outcome']}")
                console.print(f"[bold magenta]성공 기준:[/bold magenta] {scenario_info['success_criteria']}")
            else:
                console.print(f"[red]시나리오 '{info}'를 찾을 수 없습니다.[/red]")
            return

        if scenario:
            # 단일 시나리오 실행
            console.print(f"[blue]🎯 시나리오 '{scenario}' 실행 중...[/blue]")
            result = simulator.run_single_simulation(scenario)

            if result["success"]:
                console.print(f"[green]✅ 성공:[/green] {result['message']}")
            else:
                console.print(f"[red]❌ 실패:[/red] {result['message']}")

            # 상세 정보 출력
            if result["details"]:
                console.print("\n[bold]상세 정보:[/bold]")
                for key, value in result["details"].items():
                    console.print(f"  {key}: {value}")
        else:
            # 모든 시나리오 실행
            results = simulator.run_all_simulations()

            if results["passed"] == results["total_scenarios"]:
                console.print("[green]🎉 모든 시뮬레이션 통과![/green]")
            else:
                console.print(f"[yellow]⚠️ {results['failed']}개 시나리오 실패[/yellow]")

    except ImportError as e:
        print(f"❌ 모듈을 가져올 수 없습니다: {e}")
        print("💡 requirements.txt의 의존성을 확인해주세요.")
        sys.exit(1)
    except Exception as e:
        print(f"❌ 시뮬레이션 실행 중 오류 발생: {e}")
        sys.exit(1)


if __name__ == "__main__":
    simulate()